# Copy this file to .env and fill in your values
# Never commit .env to git

# AWS
AWS_REGION=ap-southeast-2
AWS_PROFILE=default
# If running on EKS with an IAM role, leave AWS_PROFILE unset

# OpenAI
OPENAI_API_KEY=sk-...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...        # Required for Socket Mode
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...           # #k8s-alerts channel ID

# Cluster
CLUSTER_NAME=otel-demo-prod
KUBECONFIG=/path/to/.kube/config

# MCP Server ports (must match servers.yaml)
KUBECTL_MCP_PORT=3001
CLOUDWATCH_MCP_PORT=3002
SLACK_MCP_PORT=3003

# Optional: LangSmith tracing (recommended for debugging agent steps)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=nz-tech-rally-demo
