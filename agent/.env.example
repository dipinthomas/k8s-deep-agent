# Copy this file to .env and fill in your values
# Never commit .env to git

# AWS — local dev only
# On EKS the pod uses IRSA (IAM Role for Service Account) — no keys needed.
AWS_REGION=ap-southeast-2
AWS_PROFILE=fernhub

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...        # Required for Socket Mode
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...           # #k8s-alerts channel ID
SLACK_TEAM_ID=T...              # Workspace ID (needed by MCP Slack server if used)

# Cluster
CLUSTER_NAME=otel-demo-prod
KUBECONFIG=/path/to/.kube/config   # local dev only; unused in-cluster

# Agent model (deepagents provider:model format)
AGENT_MODEL=anthropic:claude-sonnet-4-6

# Optional: LangSmith tracing (recommended for debugging agent steps)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=nz-tech-rally-demo
