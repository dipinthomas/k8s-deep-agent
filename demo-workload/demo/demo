#!/usr/bin/env bash
# Demo control entrypoint.
#
# Usage:
#   ./demo healthy        switch to healthy scenario, scale noisy pod to 0
#   ./demo spike          switch to spike scenario, scale noisy pod to 1
#   ./demo reset          alias for healthy
#   ./demo status         show synthesizer + (later) alarm state
#   ./demo logs           tail synth container logs
#
# Note: scenarios `spike` requires noisy-neighbor Deployment to exist
# (added in step 9 of the build plan). For steps 1-3 only `healthy` and
# `logs` / `status` are useful.

set -euo pipefail
NS=shop-prod

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$HERE/.env" ]]; then
  # shellcheck disable=SC1091
  source "$HERE/.env"
fi
export AWS_PROFILE="${AWS_PROFILE:-fernhub}"
export AWS_REGION="${AWS_REGION:-us-east-1}"

case "${1:-}" in
  healthy)
    kubectl -n "$NS" set env deploy/latency-synthesizer SCENARIO=healthy
    if kubectl -n "$NS" get deploy/inventory-sync-job >/dev/null 2>&1; then
      kubectl -n "$NS" scale deploy/inventory-sync-job --replicas=0
    fi
    echo "→ healthy. Allow ~60s for any active alarm to clear."
    ;;
  spike)
    if kubectl -n "$NS" get deploy/inventory-sync-job >/dev/null 2>&1; then
      kubectl -n "$NS" scale deploy/inventory-sync-job --replicas=1
    else
      echo "(noisy-neighbor deploy not present — only synthesizer scenario will change)"
    fi
    kubectl -n "$NS" set env deploy/latency-synthesizer SCENARIO=spike
    echo "→ spike. Alarm should fire in ~60s once that step is wired up."
    ;;
  reset)
    "$0" healthy
    echo "→ Flushing Redis investigation state..."
    kubectl exec -n k8s-agent deployment/agent-redis -- redis-cli FLUSHALL 2>/dev/null \
      && echo "→ Redis flushed." \
      || echo "⚠  Redis flush skipped (pod not ready)."
    echo "→ Resetting CloudWatch alarm to OK..."
    aws cloudwatch set-alarm-state \
      --alarm-name checkoutservice-p99-latency-high \
      --state-value OK \
      --state-reason "Demo reset" \
      --region "$AWS_REGION" 2>/dev/null \
      && echo "→ Alarm reset to OK." \
      || echo "⚠  Alarm reset skipped (alarm not found)."
    ;;
  status)
    kubectl -n "$NS" get deploy
    echo
    if command -v aws >/dev/null 2>&1; then
      echo -n "Alarm state: "
      aws cloudwatch describe-alarms \
        --alarm-names checkoutservice-p99-latency-high \
        --region "$AWS_REGION" \
        --query 'MetricAlarms[0].StateValue' --output text 2>/dev/null \
        || echo "(alarm not yet created)"
    fi
    ;;
  logs)
    kubectl -n "$NS" logs -l app=latency-synthesizer -c synth -f
    ;;
  lambda-logs)
    aws logs tail /aws/lambda/retail-prod-alarm-to-agent --follow --format short \
      --region "$AWS_REGION"
    ;;
  dlq)
    aws sqs get-queue-attributes \
      --queue-url "$(aws sqs get-queue-url --queue-name retail-prod-alarm-to-agent-dlq \
                       --region "$AWS_REGION" --query QueueUrl --output text)" \
      --attribute-names ApproximateNumberOfMessages \
      --region "$AWS_REGION" \
      --query 'Attributes.ApproximateNumberOfMessages' --output text
    ;;
  test-alarm)
    # Force the alarm into ALARM state with a realistic-looking reason.
    T1=$(date -u +"%d/%m/%y %H:%M:%S")
    T2=$(date -u -v-30S +"%d/%m/%y %H:%M:%S" 2>/dev/null || \
         date -u -d '30 seconds ago' +"%d/%m/%y %H:%M:%S" 2>/dev/null || echo "$T1")
    aws cloudwatch set-alarm-state \
      --alarm-name checkoutservice-p99-latency-high \
      --state-value ALARM \
      --state-reason "Threshold Crossed: 2 datapoints [1456.3 ($T2), 1389.7 ($T1)] were greater than the threshold (300.0)." \
      --region "$AWS_REGION"
    echo "→ Alarm in ALARM state. Watch #k8s-alerts-new for Amazon Q card + agent thread."
    ;;
  test-full)
    # Fire ALARM then OK so you can watch both the open and close cards in Slack.
    T1=$(date -u +"%d/%m/%y %H:%M:%S")
    T2=$(date -u -v-30S +"%d/%m/%y %H:%M:%S" 2>/dev/null || \
         date -u -d '30 seconds ago' +"%d/%m/%y %H:%M:%S" 2>/dev/null || echo "$T1")
    aws cloudwatch set-alarm-state \
      --alarm-name checkoutservice-p99-latency-high \
      --state-value ALARM \
      --state-reason "Threshold Crossed: 2 datapoints [1456.3 ($T2), 1389.7 ($T1)] were greater than the threshold (300.0)." \
      --region "$AWS_REGION"
    echo "→ ALARM fired. Waiting 30s then resolving..."
    sleep 30
    T1=$(date -u +"%d/%m/%y %H:%M:%S")
    T2=$(date -u -v-30S +"%d/%m/%y %H:%M:%S" 2>/dev/null || \
         date -u -d '30 seconds ago' +"%d/%m/%y %H:%M:%S" 2>/dev/null || echo "$T1")
    aws cloudwatch set-alarm-state \
      --alarm-name checkoutservice-p99-latency-high \
      --state-value OK \
      --state-reason "Threshold Crossed: 2 datapoints [24.1 ($T2), 31.8 ($T1)] were not greater than the threshold (300.0)." \
      --region "$AWS_REGION"
    echo "→ OK fired. Watch #k8s-alerts-new for the resolution card."
    ;;
  reset-chatbot)
    # AWS Chatbot tracks threads server-side (per alarm name + channel).
    # Deleting/recreating the Chatbot config does NOT clear thread state.
    # The only way to get a fresh top-level Amazon Q card is to delete the
    # last Amazon Q message from #k8s-alerts — after which the next alarm
    # creates a new top-level message.
    #
    # This command finds the most recent Amazon Q card and prints its
    # Slack ts so you can delete it manually (or auto-deletes if the bot
    # has admin permissions).
    SLACK_BOT_TOKEN="${SLACK_BOT_TOKEN:-$(kubectl get secret k8s-agent-secrets \
      -n k8s-agent -o jsonpath='{.data.SLACK_BOT_TOKEN}' 2>/dev/null | base64 -d)}"
    CHANNEL="${SLACK_CHANNEL_ID:-$(kubectl get secret k8s-agent-secrets \
      -n k8s-agent -o jsonpath='{.data.SLACK_CHANNEL_ID}' 2>/dev/null | base64 -d)}"

    echo "→ Looking for Amazon Q bot messages in #k8s-alerts-new..."
    HISTORY=$(curl -s "https://slack.com/api/conversations.history" \
      -H "Authorization: Bearer $SLACK_BOT_TOKEN" \
      --data-urlencode "channel=$CHANNEL" \
      --data-urlencode "limit=50")

    # Amazon Q Chatbot bot user ID — messages with no text and blocks from AWS Chatbot
    MSGS=$(echo "$HISTORY" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for m in data.get('messages', []):
    # Amazon Q messages have 'bot_id' set by AWS Chatbot and no plain text
    bot_id = m.get('bot_id','') or m.get('username','')
    if 'AWS' in str(m.get('username','')) or 'Amazon' in str(m.get('username','')) \
       or (m.get('bot_id') and not m.get('text')):
        print(m['ts'])
" 2>/dev/null)

    if [[ -z "$MSGS" ]]; then
      # Fallback: list recent non-agent messages
      echo "   Could not auto-detect Amazon Q messages."
      echo "   Manually delete the most recent Amazon Q alarm card from #k8s-alerts."
      echo "   (hover over the message → ⋮ → Delete message)"
    else
      FIRST_TS=$(echo "$MSGS" | head -1)
      # Try to delete — succeeds only if the bot has admin permissions
      RESULT=$(curl -s "https://slack.com/api/chat.delete" \
        -H "Authorization: Bearer $SLACK_BOT_TOKEN" \
        -H "Content-Type: application/json" \
        -d "{\"channel\":\"$CHANNEL\",\"ts\":\"$FIRST_TS\"}")
      if echo "$RESULT" | grep -q '"ok":true'; then
        echo "   ✓ Deleted Amazon Q message (ts=$FIRST_TS). Chatbot will post fresh next alarm."
      else
        ERROR=$(echo "$RESULT" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null)
        echo "   ✗ Cannot auto-delete ($ERROR — bot lacks admin permissions)."
        echo ""
        echo "   Manual step required:"
        echo "   1. Open #k8s-alerts in Slack"
        echo "   2. Find the Amazon Q card with ts ≈ $FIRST_TS"
        echo "      (the most recent '🚨 CloudWatch Alarm' card from Amazon Q)"
        echo "   3. Hover → ⋮ → Delete message"
        echo "   4. Run ./demo test-alarm — Chatbot will post a fresh card"
      fi
    fi
    ;;
  *)
    echo "Usage: $0 {healthy|spike|reset|status|logs|lambda-logs|dlq|test-alarm|test-full|reset-chatbot}"
    exit 1
    ;;
esac
