# Copy to demo/.env and fill in. demo/.env is gitignored.

# AWS profile + region used by deploy/destroy scripts.
export AWS_PROFILE=fernhub
export AWS_REGION=us-east-1

# CFN stack names.
export CLUSTER_STACK_NAME=k8s-agent-cluster
export DEMO_STACK_NAME=retail-prod-demo-workload

# Container registry. Image is built/pushed by demo/build-image.sh.
export SYNTHESIZER_IMAGE=dipinthomas2003/latency-synthesizer:v1

# Agent service location (used by deploy-aws.sh to compute AGENT_URL).
# Defaults match ../../infra/agent-deployment.yaml.
export AGENT_NAMESPACE=k8s-agent
export AGENT_SERVICE=k8s-agent
export AGENT_PORT=8080

# Override AGENT_URL directly to bypass kubectl lookup.
# export AGENT_URL=http://k8s-agent-lb-xyz.us-east-1.elb.amazonaws.com:8080/trigger

# Slack workspace + channel for AWS Chatbot. By default deploy-aws.sh
# reads these from the agent's k8s Secret (k8s-agent-secrets) — keys
# SLACK_TEAM_ID and SLACK_CHANNEL_ID. Set them here only to override
# (e.g. to point Chatbot at a different channel than the agent).
# Workspace authorization is a one-time console step — see aws/chatbot-config.md.
# export SLACK_WORKSPACE_ID=Txxxxxxxx
# export SLACK_CHANNEL_ID=Cxxxxxxxx
# export AGENT_SECRET_NAME=k8s-agent-secrets   # override secret name if different

# Alarm tuning (defaults are fine for the demo).
# export ALARM_THRESHOLD_MS=300
# export ALARM_PERIOD_SECONDS=30
# export ALARM_EVALUATION_PERIODS=2
