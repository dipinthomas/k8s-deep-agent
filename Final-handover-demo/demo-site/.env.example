# URL of the FastAPI backend (rewritten by Next.js to /api/*)
API_URL=http://localhost:8000

# Set to "true" to use real SSE stream + real fault injection
# Set to "false" (default) to run the scripted simulation
NEXT_PUBLIC_USE_REAL_API=false

# Optional: embed Headlamp at /cluster instead of the custom pod table
# NEXT_PUBLIC_HEADLAMP_URL=http://headlamp.internal
