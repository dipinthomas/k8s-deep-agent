# Set REAL_CLUSTER=true to hit real EKS — false runs in simulation mode
REAL_CLUSTER=false

# Kubernetes
NAMESPACE=otel-demo
CLUSTER_NAME=otel-demo-prod
KUBECONFIG=/root/.kube/config

# AWS (only needed when REAL_CLUSTER=true)
AWS_REGION=us-east-1
AWS_PROFILE=default

# CORS / allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://demo.1conceptonline.com
